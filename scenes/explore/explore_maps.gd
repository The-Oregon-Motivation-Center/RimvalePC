## explore_maps.gd
## Map data for all explorable subregions in Rimvale.
## Each map is a 30×22 tile grid with associated palette, buildings, POIs, and content.
## Used by explore.gd to drive the data-driven exploration engine.


## Look up the map config for a given subregion name.
## Falls back to Upper Forty if the subregion is unknown.
static func get_map(subregion: String) -> Dictionary:
	match subregion:
		# ── The Metropolitan (metro) ──
		"Upper Forty": return _upper_forty()
		"Lower Forty": return _lower_forty()
		"Eternal Library": return _eternal_library()
		"West End Gullet": return _west_end_gullet()
		"Cradling Depths": return _cradling_depths()
		"The Cradling Depths": return _cradling_depths()
		"Metropolitan": return _upper_forty()
		# ── The Plains (plains) ──
		"Kingdom of Qunorum": return _kingdom_of_qunorum()
		"Wilds of Endero": return _wilds_of_endero()
		"Forest of SubEden": return _forest_of_subeden()
		"Mortal Arena": return _mortal_arena()
		"The Plains": return _kingdom_of_qunorum()
		# ── Peaks of Isolation (peaks) ──
		"Pharaoh's Den": return _pharaohs_den()
		"Peaks of Isolation": return _pharaohs_den()
		# ── The Shadows Beneath (shadows) ──
		"The Darkness": return _the_darkness()
		"House of Arachana": return _house_of_arachana()
		"Crypt at End of Valley": return _crypt_at_end_of_valley()
		"Spindle York's Schism": return _spindle_yorks_schism()
		"Shadows Beneath": return _the_darkness()
		# ── The Glass Passage (glass) ──
		"Argent Hall": return _argent_hall()
		"Sacral Separation": return _sacral_separation()
		"Glass Passage": return _argent_hall()
		# ── The Isles (isles) ──
		"Depths of Denorim": return _depths_of_denorim()
		"Corrupted Marshes": return _corrupted_marshes()
		"Gloamfen Hollow": return _gloamfen_hollow()
		"Moroboros": return _moroboros()
		"The Isles": return _depths_of_denorim()
		# ── Titan's Lament (titans) ──
		"Vulcan Valley": return _vulcan_valley()
		"Infernal Machine": return _infernal_machine()
		"Titan's Lament": return _vulcan_valley()
		# ── The Astral Tear (astral) ──
		"Arcane Collapse": return _arcane_collapse()
		"L.I.T.O.": return _lito()
		"Land of Tomorrow": return _land_of_tomorrow()
		"Astral Tear": return _lito()
		# ── Terminus Volarus (terminus) ──
		"City of Eternal Light": return _city_of_eternal_light()
		"Hallowed Sacrament": return _hallowed_sacrament()
		"The Hallowed Sacrament": return _hallowed_sacrament()
		"Terminus Volarus": return _city_of_eternal_light()
		# ── Sublimini Dominus (sublimini) ──
		"Beating Heart of The Void": return _beating_heart_of_the_void()
		"Sublimini Dominus": return _beating_heart_of_the_void()
	return _upper_forty()

